#!/usr/bin/env bash
set -euo pipefail

agent_user="${AIYOLO_AGENT_USER:-${AIYOLO_CLAUDE_USER:-aiyolo}}"
agent_home="${AIYOLO_AGENT_HOME:-${AIYOLO_CLAUDE_HOME:-/workspace}}"
claude_config_dir="${CLAUDE_CONFIG_DIR:-${agent_home}/.claude}"

as_root=()
if [[ "${EUID}" -ne 0 ]]; then
  as_root=(sudo -n)
fi

"${as_root[@]}" install -d -m 0755 /tmp/.X11-unix
"${as_root[@]}" install -d -o "$agent_user" -g "$agent_user" -m 0755 "${XDG_RUNTIME_DIR:-/tmp/runtime-aiyolo}" /run/aiyolo /workspace "$agent_home" "$claude_config_dir"
"${as_root[@]}" chown -R "$agent_user:$agent_user" /workspace "$claude_config_dir"
"${as_root[@]}" chmod 1777 /tmp/.X11-unix

if [[ $# -eq 0 ]]; then
  set -- /usr/local/bin/aiyolo-cloud-agent-start-services
fi

exec "$@"
