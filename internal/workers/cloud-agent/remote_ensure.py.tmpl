import fcntl
import hashlib
import json
import os
import pathlib
import re
import shutil
import socket
import subprocess
import sys
import tempfile
import urllib.request

payload = json.loads(__PAYLOAD_JSON__)


def emit_progress(phase, message, **extra):
    event = {"type": "phase", "phase": phase, "message": message}
    event.update(extra)
    print("AIYOLO_PROGRESS\t" + json.dumps(event, ensure_ascii=True), file=sys.stderr, flush=True)


def emit_log(message, phase="log"):
    text = str(message or "").strip()
    if not text:
        return
    print("AIYOLO_PROGRESS\t" + json.dumps({"type": "log", "phase": phase, "message": text}, ensure_ascii=True), file=sys.stderr, flush=True)


def run(args, env=None):
    return subprocess.run(args, check=True, text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, env=env)


def run_stream(args, env=None, phase="build_image"):
    emit_progress(phase, "Running: " + " ".join(str(part) for part in args[:4]))
    process = subprocess.Popen(args, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True, env=env)
    lines = []
    if process.stdout is not None:
        for line in process.stdout:
            text = line.rstrip("\n")
            if text:
                emit_log(text, phase=phase)
                lines.append(text)
    code = process.wait()
    if code != 0:
        detail = "\n".join(lines[-20:]).strip()
        if detail:
            raise SystemExit(f"command failed ({code}): {detail}")
        raise SystemExit(f"command failed ({code}): {' '.join(str(part) for part in args)}")
    return "\n".join(lines)


def ensure_dirs():
    pathlib.Path(payload["workspace_root"]).mkdir(parents=True, exist_ok=True)
    pathlib.Path(payload["docker_data_root"]).mkdir(parents=True, exist_ok=True)


def file_sha256(path):
    digest = hashlib.sha256()
    with open(path, "rb") as handle:
        while True:
            chunk = handle.read(1024 * 1024)
            if not chunk:
                break
            digest.update(chunk)
    return digest.hexdigest()


def write_workspace_files():
    metadata = {
        "user_id": payload["user_id"],
        "agent_type": payload["agent_type"],
        "worker_id": payload["worker_id"],
        "workspace_path": payload["workspace_path"],
        "created_by": "console-chat",
        "image": payload["image"],
        "api_base_url": payload["api_base_url"],
        "console_base_url": payload.get("console_base_url", ""),
        "default_model": payload.get("default_model", ""),
        "allowed_models": payload.get("allowed_models", []),
        "open_url": payload.get("open_url", ""),
        "last_started_at": payload.get("started_at", ""),
    }
    metadata_path = pathlib.Path(payload["workspace_root"]) / ".aiyolo-cloud-agent.json"
    metadata_path.write_text(json.dumps(metadata, ensure_ascii=True, indent=2) + "\n", encoding="utf-8")
    readme_path = pathlib.Path(payload["workspace_root"]) / "README.aiyolo-cloud-agent.txt"
    readme_path.write_text(
        "AIYolo cloud-agent is running for this workspace.\n"
        "\n"
        "Container runtime exports these variables inside the container:\n"
        "- OPENAI_BASE_URL / OPENAI_API_BASE\n"
        "- OPENAI_API_KEY\n"
        "- AIYOLO_API_BASE_URL / AIYOLO_API_ROOT_URL\n"
        "- AIYOLO_DEFAULT_MODEL / AIYOLO_ALLOWED_MODELS\n"
        "\n"
        "Open the browser inside the container at:\n"
        f"{payload.get('open_url', '')}\n",
        encoding="utf-8",
    )


def resolve_rootfs_url():
    if payload.get("rootfs_url"):
        return payload["rootfs_url"].strip()
    rootfs_index_url = payload["rootfs_index_url"].rstrip("/")
    rootfs_pattern = r"ubuntu-base-" + re.escape(payload["ubuntu_series"]) + r"(?:\.[0-9]+)?-base-amd64\.tar\.gz"
    with urllib.request.urlopen(rootfs_index_url + "/", timeout=30) as response:
        index_html = response.read().decode("utf-8", errors="replace")
    matches = re.findall(rootfs_pattern, index_html)
    if not matches:
        with urllib.request.urlopen(rootfs_index_url + "/SHA256SUMS", timeout=30) as response:
            sums = response.read().decode("utf-8", errors="replace")
        matches = re.findall(rootfs_pattern, sums)
    if not matches:
        raise SystemExit("unable to resolve Ubuntu base rootfs from index")
    matches = sorted(set(matches), key=lambda item: tuple(int(part) for part in re.findall(r"\d+", item)))
    return rootfs_index_url + "/" + matches[-1]


def inspect_image():
    result = run(["docker", "image", "inspect", payload["image"]])
    return json.loads(result.stdout)[0]


def expected_ass_sha256():
    return str(payload.get("ass_sha256", "")).strip()


def expected_build_revision():
    return str(payload.get("build_revision", "")).strip()


def image_label(inspected, key):
    labels = inspected.get("Config", {}).get("Labels") or {}
    value = labels.get(key)
    if value is None:
        return ""
    return str(value)


def image_ass_sha256_matches():
    expected_ass = expected_ass_sha256()
    expected_revision = expected_build_revision()
    if not expected_ass and not expected_revision:
        return True
    try:
        inspected = inspect_image()
    except subprocess.CalledProcessError:
        return False
    if expected_ass and image_label(inspected, "aiyolo.ass.sha256") != expected_ass:
        return False
    if expected_revision and image_label(inspected, "aiyolo.cloud_agent.build_revision") != expected_revision:
        return False
    return True


def container_ass_sha256_matches(inspected):
    expected = expected_ass_sha256()
    if not expected:
        return True
    labels = inspected.get("Config", {}).get("Labels") or {}
    value = labels.get("aiyolo.ass.sha256")
    if value is None:
        return False
    return str(value) == expected


def container_build_revision_matches(inspected):
    expected = expected_build_revision()
    if not expected:
        return True
    labels = inspected.get("Config", {}).get("Labels") or {}
    value = labels.get("aiyolo.cloud_agent.build_revision")
    if value is None:
        return False
    return str(value) == expected


def replace_container_for_ass_upgrade():
    if not exact_container_id():
        return
    emit_progress("upgrade_container", "Replacing cloud agent container for aiyolo-ass upgrade")
    run(["docker", "stop", "-t", "10", payload["container_name"]])
    run(["docker", "rm", payload["container_name"]])


def ensure_image(force_rebuild=False):
    if not force_rebuild and image_ass_sha256_matches():
        emit_progress("reuse_image", "Cloud agent image already matches the published aiyolo-ass checksum")
        return
    emit_progress("build_image", "Building cloud agent image with the latest aiyolo-ass")
    build_env = os.environ.copy()
    for key, value in (payload.get("proxy_env") or {}).items():
        build_env[key] = value
    temp_root = pathlib.Path(tempfile.mkdtemp(prefix="aiyolo-cloud-agent-build-"))
    try:
        for relative_path, content in (payload.get("files") or {}).items():
            target_path = temp_root / relative_path
            target_path.parent.mkdir(parents=True, exist_ok=True)
            target_path.write_text(content, encoding="utf-8")
        ass_path = temp_root / "aiyolo-ass"
        emit_progress("download_ass", "Downloading aiyolo-ass release binary")
        with urllib.request.urlopen(payload["ass_download_url"], timeout=60) as response, open(ass_path, "wb") as handle:
            shutil.copyfileobj(response, handle)
        actual_ass_sha256 = file_sha256(ass_path)
        if actual_ass_sha256 != payload.get("ass_sha256", ""):
            raise SystemExit(f"downloaded aiyolo-ass checksum mismatch: {actual_ass_sha256}")
        ass_path.chmod(0o755)
        emit_progress("download_rootfs", "Downloading Ubuntu base rootfs")
        rootfs_url = resolve_rootfs_url()
        rootfs_path = temp_root / "rootfs.tar.gz"
        with urllib.request.urlopen(rootfs_url, timeout=60) as response, open(rootfs_path, "wb") as handle:
            shutil.copyfileobj(response, handle)
        build_args = [
            "docker", "build", "--pull",
            "--build-arg", f"UBUNTU_RELEASE={payload['ubuntu_release']}",
            "--build-arg", f"APT_MIRROR={payload['ubuntu_mirror']}",
            "--build-arg", f"CHROME_DEB_URL={payload['chrome_deb_url']}",
            "--build-arg", f"AIYOLO_ASS_SHA256={payload.get('ass_sha256', '')}",
            "--build-arg", f"AIYOLO_CLOUD_AGENT_BUILD_REVISION={payload.get('build_revision', '')}",
        ]
        for key in sorted((payload.get("proxy_env") or {}).keys()):
            build_args.extend(["--build-arg", f"{key}={payload['proxy_env'][key]}"])
        build_args.extend(["-t", payload["image"], "-f", str(temp_root / "Dockerfile"), str(temp_root)])
        run_stream(build_args, env=build_env, phase="build_image")
    finally:
        shutil.rmtree(temp_root, ignore_errors=True)


def inspect_container():
    result = run(["docker", "inspect", payload["container_name"]])
    return json.loads(result.stdout)[0]


def exact_container_id():
    result = run(["docker", "ps", "-a", "--filter", f"name=^/{payload['container_name']}$", "--format", "{{.ID}}"])
    return result.stdout.strip()


def container_summary(inspected):
    current_env = env_map(inspected)
    allowed_models = payload.get("allowed_models", [])
    if current_env.get("AIYOLO_ALLOWED_MODELS"):
        allowed_models = [item.strip() for item in current_env["AIYOLO_ALLOWED_MODELS"].split(",") if item.strip()]
    summary = {
        "status": "running" if inspected["State"].get("Running") else "stopped",
        "worker_id": payload["worker_id"],
        "container_id": inspected["Id"],
        "container_name": payload["container_name"],
        "image": inspected["Config"].get("Image", payload["image"]),
        "workspace_root": mount_source(inspected, payload["workspace_path"]) or payload["workspace_root"],
        "workspace_path": payload["workspace_path"],
        "docker_data_root": mount_source(inspected, "/var/lib/docker") or payload["docker_data_root"],
        "default_model": current_env.get("AIYOLO_DEFAULT_MODEL", payload.get("default_model", "")),
        "allowed_models": allowed_models,
        "console_url": current_env.get("AIYOLO_CLOUD_AGENT_CHROME_URL", payload.get("open_url", "")),
        "api_base_url": current_env.get("AIYOLO_API_BASE_URL", payload.get("api_base_url", "")),
        "last_started_at": inspected.get("State", {}).get("StartedAt") or payload.get("started_at", ""),
    }
    if payload.get("enable_display"):
        summary["vnc"] = f"127.0.0.1:{payload['host_vnc_port']}"
    if payload.get("enable_display") and payload.get("auto_start_chrome"):
        summary["chrome_devtools"] = f"http://127.0.0.1:{payload['host_chrome_port']}/json/version"
    summary["ass_base_url"] = f"http://127.0.0.1:{payload['host_ass_port']}"
    return summary


def env_map(inspected):
    env = {}
    for entry in inspected.get("Config", {}).get("Env") or []:
        if "=" not in entry:
            continue
        key, value = entry.split("=", 1)
        env[key] = value
    return env


def mount_source(inspected, destination):
    for mount in inspected.get("Mounts") or []:
        if mount.get("Destination") == destination:
            return mount.get("Source", "")
    return ""


def label_matches(labels, key, expected):
    actual = labels.get(key)
    return actual is None or actual == str(expected)


def container_matches(inspected):
    labels = inspected.get("Config", {}).get("Labels") or {}
    if not label_matches(labels, "aiyolo.user_id", payload["user_id"]):
        return False
    if not label_matches(labels, "aiyolo.agent_type", payload["agent_type"]):
        return False
    if not label_matches(labels, "aiyolo.workspace_path", payload["workspace_path"]):
        return False
    if not label_matches(labels, "aiyolo.ass.container_port", payload.get("container_ass_port", "")):
        return False
    if not label_matches(labels, "aiyolo.ass.host_port", payload.get("host_ass_port", "")):
        return False
    if mount_source(inspected, payload["workspace_path"]) != payload["workspace_root"]:
        return False
    if mount_source(inspected, "/var/lib/docker") != payload["docker_data_root"]:
        return False
    return True


def container_can_migrate_agent_type(inspected):
    labels = inspected.get("Config", {}).get("Labels") or {}
    actual_agent_type = str(labels.get("aiyolo.agent_type") or "").strip()
    target_agent_type = str(payload.get("agent_type") or "").strip()
    if actual_agent_type == "" or target_agent_type == "" or actual_agent_type == target_agent_type:
        return False
    # Only auto-replace when container identity still matches this user/session shape.
    if not label_matches(labels, "aiyolo.user_id", payload["user_id"]):
        return False
    if not label_matches(labels, "aiyolo.workspace_path", payload["workspace_path"]):
        return False
    if not label_matches(labels, "aiyolo.ass.container_port", payload.get("container_ass_port", "")):
        return False
    if not label_matches(labels, "aiyolo.ass.host_port", payload.get("host_ass_port", "")):
        return False
    if mount_source(inspected, payload["workspace_path"]) != payload["workspace_root"]:
        return False
    if mount_source(inspected, "/var/lib/docker") != payload["docker_data_root"]:
        return False
    return True


def wait_for(command, timeout_seconds):
    deadline = time.time() + timeout_seconds
    while time.time() < deadline:
        probe_timeout = max(0.1, min(5, deadline - time.time()))
        try:
            subprocess.run(command, check=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, timeout=probe_timeout)
            return
        except (subprocess.CalledProcessError, subprocess.TimeoutExpired):
            time.sleep(min(1, max(0, deadline - time.time())))
    raise SystemExit("timed out waiting for container service")


def wait_for_tcp(host, port, timeout_seconds):
    deadline = time.time() + timeout_seconds
    port = int(port)
    while time.time() < deadline:
        try:
            with socket.create_connection((host, port), timeout=2):
                return
        except OSError:
            time.sleep(1)
    raise SystemExit(f"timed out waiting for TCP service {host}:{port}")


def acquire_container_lock():
    lock_name = re.sub(r"[^0-9A-Za-z_.-]", "-", payload["container_name"])
    lock_path = pathlib.Path("/tmp") / f"{lock_name}.lock"
    lock_handle = lock_path.open("w")
    fcntl.flock(lock_handle.fileno(), fcntl.LOCK_EX)
    return lock_handle


def wait_for_container_runtime():
    # Chat, shell, and workspace APIs only need the ASS control plane; display,
    # Chrome, and dockerd continue starting inside the already-running container.
    wait_for(["docker", "exec", payload["container_name"], "bash", "-lc", "test -S ${AIYOLO_ASS_SOCKET_PATH:-/run/aiyolo/ass.sock}"], 30)
    wait_for_tcp("127.0.0.1", payload["host_ass_port"], 30)


def container_has_claude_cli():
    result = subprocess.run(
        ["docker", "exec", payload["container_name"], "bash", "-lc", "command -v claude >/dev/null 2>&1"],
        check=False,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )
    return result.returncode == 0


def ensure_container():
    existing_id = exact_container_id()
    if existing_id:
        try:
            inspected = inspect_container()
        except subprocess.CalledProcessError as exc:
            detail = (exc.stdout or "").strip()
            suffix = f": {detail}" if detail else ""
            raise SystemExit(f"failed to inspect existing cloud agent container {payload['container_name']}; stop and remove it manually before retrying{suffix}")
        if not container_matches(inspected):
            if container_can_migrate_agent_type(inspected):
                emit_progress("upgrade_container", "Replacing cloud agent container for agent type migration")
                run(["docker", "stop", "-t", "10", payload["container_name"]])
                run(["docker", "rm", payload["container_name"]])
                ensure_image()
            else:
                raise SystemExit(f"cloud agent container {payload['container_name']} already exists but does not match the expected user, workspace, or ASS port; stop and remove it manually before starting a replacement")
        if not container_build_revision_matches(inspected):
            emit_progress("upgrade_container", "Replacing cloud agent container for image revision update")
            run(["docker", "stop", "-t", "10", payload["container_name"]])
            run(["docker", "rm", payload["container_name"]])
            ensure_image()
        if not container_ass_sha256_matches(inspected):
            replace_container_for_ass_upgrade()
            ensure_image()
        else:
            if not inspected.get("State", {}).get("Running"):
                emit_progress("start_container", "Starting existing cloud agent container")
                run(["docker", "start", payload["container_name"]])
            else:
                emit_progress("reuse_container", "Reusing existing cloud agent container")
            if not container_has_claude_cli():
                emit_progress("upgrade_container", "Replacing cloud agent container because claude CLI is missing")
                run(["docker", "stop", "-t", "10", payload["container_name"]])
                run(["docker", "rm", payload["container_name"]])
                ensure_image(force_rebuild=True)
            else:
                emit_progress("wait_runtime", "Waiting for aiyolo-ass control plane")
                wait_for_container_runtime()
                return container_summary(inspect_container())
    ensure_image()
    emit_progress("create_container", "Creating cloud agent container")
    args = [
        "docker", "run", "-d",
        "--name", payload["container_name"],
        "--hostname", payload["container_name"],
        "--restart", "unless-stopped",
        "--add-host", "host.docker.internal:host-gateway",
        "--privileged",
        "--shm-size", payload["shm_size"],
        "--label", f"aiyolo.user_id={payload['user_id']}",
        "--label", f"aiyolo.agent_type={payload['agent_type']}",
        "--label", f"aiyolo.workspace_path={payload['workspace_path']}",
        "--label", f"aiyolo.cloud_agent.build_revision={payload.get('build_revision', '')}",
        "--label", f"aiyolo.ass.sha256={payload.get('ass_sha256', '')}",
        "--label", f"aiyolo.ass.container_port={payload['container_ass_port']}",
        "--label", f"aiyolo.ass.host_port={payload['host_ass_port']}",
    ]
    for key in sorted((payload.get("container_env") or {}).keys()):
        args.extend(["-e", f"{key}={payload['container_env'][key]}"])
    args.extend(["-v", f"{payload['workspace_root']}:{payload['workspace_path']}"])
    args.extend(["-v", f"{payload['docker_data_root']}:/var/lib/docker"])
    args.extend(["-w", payload["workspace_path"]])
    if payload.get("enable_display"):
        args.extend(["-p", f"127.0.0.1:{payload['host_vnc_port']}:{payload['container_vnc_port']}"])
    if payload.get("enable_display") and payload.get("auto_start_chrome"):
        args.extend(["-p", f"127.0.0.1:{payload['host_chrome_port']}:{payload['container_chrome_port']}"])
    args.extend(["-p", f"127.0.0.1:{payload['host_ass_port']}:{payload['container_ass_port']}"])
    args.append(payload["image"])
    run(args)
    emit_progress("wait_runtime", "Waiting for aiyolo-ass control plane")
    wait_for_container_runtime()
    return container_summary(inspect_container())


if __name__ == "__main__":
    import time

    emit_progress("prepare", "Preparing cloud agent workspace")
    ensure_dirs()
    write_workspace_files()
    emit_progress("lock", "Acquiring cloud agent container lock")
    lock_handle = acquire_container_lock()
    try:
        summary = ensure_container()
        emit_progress("ready", "Cloud agent runtime is ready", container_name=summary.get("container_name", ""))
        print(json.dumps(summary, ensure_ascii=True, sort_keys=True))
    finally:
        lock_handle.close()
