#!/usr/bin/env python3
import argparse
import json
import os
from http import HTTPStatus
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer


def load_config(path: str) -> dict:
    with open(path, "r", encoding="utf-8") as handle:
        return json.load(handle)


def health_payload(config: dict) -> tuple[dict, bool]:
    data_root = config.get("data_root", "")
    workspace_root = config.get("workspace_root", "")
    payload = {
        "status": "ready",
        "worker_id": config.get("worker_id", ""),
        "data_root": data_root,
        "workspace_root": workspace_root,
        "docker_socket_exists": os.path.exists("/var/run/docker.sock"),
        "data_root_exists": os.path.isdir(data_root),
        "workspace_root_exists": os.path.isdir(workspace_root),
        "service_name": config.get("service_name", "{{ worker_runtime_service_name }}"),
    }
    ready = payload["docker_socket_exists"] and payload["data_root_exists"] and payload["workspace_root_exists"]
    if not ready:
        payload["status"] = "degraded"
    return payload, ready


class Handler(BaseHTTPRequestHandler):
    config = None

    def do_GET(self) -> None:
        payload, ready = health_payload(self.config)
        if self.path == "/healthz":
            payload["status"] = "ok"
            self._write(HTTPStatus.OK, payload)
            return
        if self.path == "/readyz":
            self._write(HTTPStatus.OK if ready else HTTPStatus.SERVICE_UNAVAILABLE, payload)
            return
        self._write(HTTPStatus.NOT_FOUND, {"status": "not_found"})

    def log_message(self, format: str, *args) -> None:
        return

    def _write(self, status: HTTPStatus, payload: dict) -> None:
        body = json.dumps(payload, sort_keys=True).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)


def main() -> None:
    parser = argparse.ArgumentParser()
    parser.add_argument("--config", required=True)
    args = parser.parse_args()
    config = load_config(args.config)
    os.makedirs(config["data_root"], exist_ok=True)
    os.makedirs(config["workspace_root"], exist_ok=True)
    Handler.config = config
    server = ThreadingHTTPServer((config.get("listen_host", "127.0.0.1"), int(config.get("listen_port", 17810))), Handler)
    server.serve_forever()


if __name__ == "__main__":
    main()
