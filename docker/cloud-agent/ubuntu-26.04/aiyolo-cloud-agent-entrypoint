#!/usr/bin/env bash
set -euo pipefail

claude_user="${AIYOLO_CLAUDE_USER:-aiyolo}"
claude_home="${AIYOLO_CLAUDE_HOME:-/workspace}"

as_root=()
if [[ "${EUID}" -ne 0 ]]; then
  as_root=(sudo -n)
fi

"${as_root[@]}" install -d -m 0755 /tmp/.X11-unix
"${as_root[@]}" install -d -o "$claude_user" -g "$claude_user" -m 0755 "${XDG_RUNTIME_DIR:-/tmp/runtime-aiyolo}" /run/aiyolo /workspace "$claude_home" "$claude_home/.claude"
"${as_root[@]}" chown -R "$claude_user:$claude_user" /workspace "$claude_home/.claude"
"${as_root[@]}" chmod 1777 /tmp/.X11-unix

if [[ $# -eq 0 ]]; then
  set -- /usr/local/bin/aiyolo-cloud-agent-start-services
fi

exec "$@"
