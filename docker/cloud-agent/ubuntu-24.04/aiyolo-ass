#!/usr/bin/env python3
import datetime
import hashlib
import json
import os
import posixpath
import pwd
import shutil
import signal
import socketserver
import subprocess
import tempfile
import threading
import time
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from urllib.parse import parse_qs, urlparse

SERVICE = "aiyolo-ass"
VERSION = "0.1.0"
ROOT = os.path.realpath(os.environ.get("AIYOLO_ASS_WORKSPACE_ROOT", "/workspace"))
EXEC_USER = os.environ.get("AIYOLO_ASS_USER", "aiyolo")
EXEC_HOME = os.environ.get("AIYOLO_ASS_HOME", "/workspace")
MAX_FILE_BYTES = int(os.environ.get("AIYOLO_ASS_MAX_FILE_BYTES", "524288") or "524288")
MAX_TREE_ENTRIES = int(os.environ.get("AIYOLO_ASS_MAX_TREE_ENTRIES", "1000") or "1000")
MAX_EXEC_OUTPUT_BYTES = int(os.environ.get("AIYOLO_ASS_MAX_EXEC_OUTPUT_BYTES", "1048576") or "1048576")
DEFAULT_SOCKET = "/run/aiyolo/ass.sock"


class APIError(Exception):
    def __init__(self, status, code, message, retryable=False):
        super().__init__(message)
        self.status = status
        self.code = code
        self.message = message
        self.retryable = retryable


def revision(payload):
    return "sha256:" + hashlib.sha256(payload).hexdigest()


def normalize_path(raw, allow_root):
    raw = (raw or "").strip().replace("\\", "/")
    if "\x00" in raw:
        raise APIError(400, "path_invalid", "workspace path is invalid")
    if raw in ("", ".", "/"):
        if allow_root:
            return ""
        raise APIError(400, "path_invalid", "workspace file path is required")
    for segment in raw.split("/"):
        if segment == "..":
            raise APIError(400, "path_invalid", "workspace path escapes root")
    cleaned = posixpath.normpath("/" + raw).lstrip("/")
    if cleaned in ("", "."):
        if allow_root:
            return ""
        raise APIError(400, "path_invalid", "workspace file path is required")
    return cleaned


def inside_root(real_path):
    rel = os.path.relpath(real_path, ROOT)
    return rel == "." or (rel != ".." and not rel.startswith("../"))


def resolve_existing(raw, allow_root):
    rel = normalize_path(raw, allow_root)
    real = os.path.realpath(os.path.join(ROOT, rel))
    if not inside_root(real):
        raise APIError(400, "path_invalid", "workspace path escapes root")
    if not os.path.exists(real):
        raise APIError(404, "path_not_found", "workspace path does not exist")
    return rel, real, os.stat(real)


def read_text_file(real, stat_result):
    if stat_result.st_size > MAX_FILE_BYTES:
        raise APIError(413, "file_too_large", "workspace file exceeds the editable size limit")
    with open(real, "rb") as handle:
        payload = handle.read(MAX_FILE_BYTES + 1)
    if len(payload) > MAX_FILE_BYTES:
        raise APIError(413, "file_too_large", "workspace file exceeds the editable size limit")
    if b"\x00" in payload:
        raise APIError(415, "file_binary", "workspace file is binary and cannot be edited")
    try:
        payload.decode("utf-8")
    except UnicodeDecodeError:
        raise APIError(415, "encoding_invalid", "workspace file is not valid UTF-8")
    return payload


def directory_has_children(real, include_hidden):
    try:
        with os.scandir(real) as iterator:
            for entry in iterator:
                if entry.name in (".", "..") or (not include_hidden and entry.name.startswith(".")):
                    continue
                if entry.is_symlink():
                    continue
                if entry.is_dir(follow_symlinks=False) or entry.is_file(follow_symlinks=False):
                    return True
    except OSError:
        return False
    return False


def list_tree(raw_path, limit, include_hidden):
    rel, real, _ = resolve_existing(raw_path, True)
    if not os.path.isdir(real):
        raise APIError(400, "path_not_directory", "workspace path is not a directory")
    entries = []
    with os.scandir(real) as iterator:
        for entry in iterator:
            if entry.name in (".", "..") or (not include_hidden and entry.name.startswith(".")):
                continue
            if entry.is_symlink():
                continue
            try:
                stat_result = entry.stat(follow_symlinks=False)
            except OSError:
                continue
            if entry.is_dir(follow_symlinks=False):
                entry_type = "directory"
            elif entry.is_file(follow_symlinks=False):
                entry_type = "file"
            else:
                continue
            entry_path = posixpath.join(rel, entry.name) if rel else entry.name
            entries.append({
                "name": entry.name,
                "path": entry_path,
                "type": entry_type,
                "size": int(stat_result.st_size),
                "modified_at": datetime.datetime.fromtimestamp(stat_result.st_mtime, datetime.timezone.utc).isoformat().replace("+00:00", "Z"),
                "has_children": entry_type == "directory" and directory_has_children(entry.path, include_hidden),
            })
    entries.sort(key=lambda item: (0 if item["type"] == "directory" else 1, item["name"].lower(), item["name"]))
    truncated = len(entries) > limit
    return {"path": rel, "entries": entries[:limit], "truncated": truncated}


def write_file(request):
    rel = normalize_path(request.get("path", ""), False)
    content = request.get("content", "")
    if not isinstance(content, str):
        raise APIError(415, "encoding_invalid", "workspace file content is invalid")
    payload = content.encode("utf-8")
    if len(payload) > MAX_FILE_BYTES:
        raise APIError(413, "file_too_large", "workspace file exceeds the editable size limit")
    if b"\x00" in payload:
        raise APIError(415, "file_binary", "workspace file content contains NUL bytes")
    target = os.path.realpath(os.path.join(ROOT, rel))
    if not inside_root(target):
        raise APIError(400, "path_invalid", "workspace path escapes root")
    if not os.path.exists(target):
        if not request.get("create", False):
            raise APIError(404, "path_not_found", "workspace file does not exist")
        parent = os.path.realpath(os.path.dirname(target))
        if request.get("mkdir_p", False):
            os.makedirs(parent, exist_ok=True)
        if not inside_root(parent) or not os.path.isdir(parent):
            raise APIError(404, "path_not_found", "workspace parent directory does not exist")
        mode = 0o644
        owner = None
    else:
        if not os.path.isfile(target):
            raise APIError(400, "path_not_file", "workspace path is not a file")
        stat_result = os.stat(target)
        current = read_text_file(target, stat_result)
        expected = (request.get("expected_revision") or "").strip()
        if expected and expected != revision(current):
            raise APIError(409, "conflict", "workspace file revision does not match")
        mode = stat_result.st_mode & 0o777
        owner = (stat_result.st_uid, stat_result.st_gid)
    fd, tmp = tempfile.mkstemp(prefix=".aiyolo-ass-", dir=os.path.dirname(target))
    try:
        with os.fdopen(fd, "wb") as handle:
            handle.write(payload)
            handle.flush()
            os.fsync(handle.fileno())
        os.chmod(tmp, mode)
        if owner:
            try:
                os.chown(tmp, owner[0], owner[1])
            except PermissionError:
                pass
        os.replace(tmp, target)
    finally:
        if os.path.exists(tmp):
            os.unlink(tmp)
    return {"path": rel, "bytes": len(payload), "revision": revision(payload)}


def exec_preexec():
    os.setsid()
    if os.geteuid() != 0 or not EXEC_USER:
        return
    user_info = pwd.getpwnam(EXEC_USER)
    os.setgid(user_info.pw_gid)
    try:
        os.initgroups(EXEC_USER, user_info.pw_gid)
    except OSError:
        pass
    os.setuid(user_info.pw_uid)


def run_exec(request):
    mode = (request.get("mode") or "").strip().lower()
    if mode == "bash":
        script = request.get("script") or ""
        if not script.strip():
            raise APIError(400, "exec_invalid", "bash script is required")
        argv = ["/bin/bash", "-lc", script]
    elif mode == "argv":
        argv = request.get("argv") or []
        if not argv or not str(argv[0]).strip():
            raise APIError(400, "exec_invalid", "argv command is required")
        argv = [str(item) for item in argv]
    else:
        raise APIError(400, "exec_invalid", "exec mode must be bash or argv")
    cwd_rel, cwd_real, _ = resolve_existing(request.get("cwd") or "", True)
    if not os.path.isdir(cwd_real):
        raise APIError(400, "path_not_directory", "exec cwd is not a directory")
    env = os.environ.copy()
    env.update({"HOME": EXEC_HOME, "USER": EXEC_USER, "SHELL": "/bin/bash"})
    protected = {"HOME", "USER", "PATH", "SHELL"}
    for key, value in (request.get("env") or {}).items():
        key = str(key).strip()
        if not key or "=" in key or "\x00" in key or "\x00" in str(value):
            raise APIError(400, "exec_invalid", "exec environment contains an invalid variable")
        if key in protected:
            raise APIError(400, "exec_invalid", "exec environment cannot override " + key)
        env[key] = str(value)
    timeout = (int(request.get("timeout_ms") or 30000) / 1000.0)
    max_output = int(request.get("max_output_bytes") or 262144)
    max_output = min(max_output, MAX_EXEC_OUTPUT_BYTES)
    started = time.monotonic()
    proc = subprocess.Popen(argv, cwd=cwd_real, env=env, stdin=subprocess.PIPE, stdout=subprocess.PIPE, stderr=subprocess.PIPE, preexec_fn=exec_preexec)
    timed_out = False
    try:
        stdout, stderr = proc.communicate((request.get("stdin") or "").encode("utf-8"), timeout=timeout)
    except subprocess.TimeoutExpired:
        timed_out = True
        try:
            os.killpg(proc.pid, signal.SIGKILL)
        except OSError:
            proc.kill()
        stdout, stderr = proc.communicate()
    combined = len(stdout) + len(stderr)
    truncated = combined > max_output
    if truncated:
        remaining = max_output
        stdout = stdout[:remaining]
        remaining -= len(stdout)
        stderr = stderr[:max(0, remaining)]
    return {
        "mode": mode,
        "cwd": cwd_rel,
        "exit_code": -1 if timed_out else int(proc.returncode or 0),
        "timed_out": timed_out,
        "stdout": stdout.decode("utf-8", errors="replace"),
        "stderr": stderr.decode("utf-8", errors="replace"),
        "truncated": truncated,
        "duration_ms": int((time.monotonic() - started) * 1000),
    }


class Handler(BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        return

    def write_json(self, status, payload):
        body = json.dumps(payload, ensure_ascii=False).encode("utf-8") + b"\n"
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def ok(self, data):
        self.write_json(200, {"status": "ok", "data": data})

    def fail(self, exc):
        if not isinstance(exc, APIError):
            exc = APIError(500, "internal_error", str(exc))
        self.write_json(exc.status, {"status": "error", "error": {"code": exc.code, "message": exc.message, "retryable": exc.retryable}})

    def read_json(self):
        length = int(self.headers.get("Content-Length") or "0")
        return json.loads(self.rfile.read(length).decode("utf-8") if length else "{}")

    def do_GET(self):
        try:
            parsed = urlparse(self.path)
            query = parse_qs(parsed.query)
            if parsed.path == "/v1/healthz":
                if not os.path.isdir(ROOT):
                    raise APIError(500, "internal_error", "workspace root is not available")
                self.ok({"service": SERVICE, "version": VERSION, "workspace_root": ROOT})
            elif parsed.path == "/v1/fs/tree":
                limit = min(int((query.get("limit") or ["200"])[0]), MAX_TREE_ENTRIES)
                include_hidden = (query.get("include_hidden") or ["false"])[0].lower() in ("1", "true", "yes", "on")
                self.ok(list_tree((query.get("path") or [""])[0], limit, include_hidden))
            elif parsed.path == "/v1/fs/file":
                rel, real, stat_result = resolve_existing((query.get("path") or [""])[0], False)
                if not os.path.isfile(real):
                    raise APIError(400, "path_not_file", "workspace path is not a file")
                payload = read_text_file(real, stat_result)
                self.ok({"path": rel, "size": len(payload), "revision": revision(payload), "content": payload.decode("utf-8")})
            else:
                raise APIError(404, "path_not_found", "route not found")
        except Exception as exc:
            self.fail(exc)

    def do_PUT(self):
        try:
            if urlparse(self.path).path != "/v1/fs/file":
                raise APIError(404, "path_not_found", "route not found")
            self.ok(write_file(self.read_json()))
        except Exception as exc:
            self.fail(exc)

    def do_POST(self):
        try:
            if urlparse(self.path).path != "/v1/shell/exec":
                raise APIError(404, "path_not_found", "route not found")
            self.ok(run_exec(self.read_json()))
        except Exception as exc:
            self.fail(exc)


class ThreadingUnixServer(socketserver.ThreadingMixIn, socketserver.UnixStreamServer):
    daemon_threads = True


def serve():
    servers = []
    socket_path = os.environ.get("AIYOLO_ASS_SOCKET_PATH", DEFAULT_SOCKET).strip()
    if socket_path and socket_path != "-":
        os.makedirs(os.path.dirname(socket_path), exist_ok=True)
        try:
            os.unlink(socket_path)
        except FileNotFoundError:
            pass
        server = ThreadingUnixServer(socket_path, Handler)
        os.chmod(socket_path, 0o660)
        servers.append(server)
    http_addr = os.environ.get("AIYOLO_ASS_HTTP_ADDR", "").strip()
    if http_addr:
        host, port = http_addr.rsplit(":", 1)
        servers.append(ThreadingHTTPServer((host, int(port)), Handler))
    if not servers:
        raise SystemExit("AIYOLO_ASS_SOCKET_PATH or AIYOLO_ASS_HTTP_ADDR is required")
    for server in servers:
        threading.Thread(target=server.serve_forever, daemon=True).start()
    try:
        while True:
            time.sleep(3600)
    finally:
        for server in servers:
            server.shutdown()


if __name__ == "__main__":
    serve()
